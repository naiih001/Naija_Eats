generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String // Note: Store as hashed password
  phone_number   String?
  profile        Profile?
  isVerified     Boolean   @default(false)
  verifyToken    String?   @unique
  verifyTokenExp DateTime?
  resetToken     String?   @unique
  resetTokenExp  DateTime?
  created_at     DateTime  @default(now())
}

model Profile {
  id         String @id @default(uuid())
  user_id    String @unique
  full_name  String
  avatar_url String @default("")
  user       User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model budgets {
  id                 String  @id @default(uuid())
  user_id            String  @unique
  tier               String?
  value              String?
  frequency          String?
  fluctuation_buffer String?
}

model household_profiles {
  id                String  @id @default(uuid())
  user_id           String  @unique
  household_size    String?
  daily_meals       String?
  is_dessert        Boolean @default(false)
  cooking_frequency String?
}

model user_preferences {
  id         String @id @default(uuid())
  user_id    String
  preference String
}

model user_allergies {
  id      String @id @default(uuid())
  user_id String
  allergy String
}

model dietary_tags {
  id      String @id @default(uuid())
  user_id String
  tag     String
}

model meals {
  id             String            @id @default(uuid())
  name           String
  category       String
  price_min      Decimal?
  price_max      Decimal?
  prep_time_mins Int?
  dietary_tags   String?
  instructions   String?
  plan_items     meal_plan_items[]
}

model meal_plans {
  id            String                @id @default(uuid())
  user_id       String
  status        String
  items         meal_plan_items[]
  shopping_list shopping_list_items[]
}

model meal_plan_items {
  id          String     @id @default(uuid())
  plan_id     String
  plan        meal_plans @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  meal_id     String
  meal        meals      @relation(fields: [meal_id], references: [id])
  day_of_week String
  meal_slot   String
}

model shopping_list_items {
  id           String     @id @default(uuid())
  meal_plan_id String
  plan         meal_plans @relation(fields: [meal_plan_id], references: [id], onDelete: Cascade)
  name         String
  category     String?
  quantity     String?
}
